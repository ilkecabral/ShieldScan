# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Database — SQLite by default, switch to PostgreSQL for production
DATABASE_URL=sqlite:///./shieldscan.db
# DATABASE_URL=postgresql://user:password@localhost:5432/shieldscan

# JWT — generate a strong random secret for production
# Python: import secrets; secrets.token_hex(32)
JWT_SECRET_KEY=change-this-to-a-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# AWS credential encryption key — generate with:
# Python: from cryptography.fernet import Fernet; Fernet.generate_key().decode()
AWS_ENCRYPTION_KEY=your-fernet-key-here

# AI provider: ollama | groq | claude
AI_PROVIDER=ollama
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# Groq (free tier — use when deploying to Oracle Cloud)
# Sign up free at: https://console.groq.com → API Keys → Create
# GROQ_API_KEY=your-groq-api-key
# GROQ_MODEL=llama-3.3-70b-versatile

# Claude API (paid — optional, only if you want to upgrade later)
# ANTHROPIC_API_KEY=your-anthropic-api-key
# CLAUDE_MODEL=claude-haiku-4-5-20251001
